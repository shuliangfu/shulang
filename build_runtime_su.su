// build_runtime_su.su — build_tool 完全无 C：run_step 与 patch 的 .su 实现
//
// 与 build_runner.su 配合：本文件提供 build_run_step(step_id, shuc_path)，由 build_runner.su 的 entry 调用。
// 链接时仅需 crt0 + build_runner.o + build_tool.o + build_runtime_su.o + -lc，不再链接 build_runtime.c。
// 字面量与 build_runtime.c 的 run_step 一致；patch 使用 libc 的 fopen/fread/fwrite/strstr/memmove。

/** libc：执行命令行。 */
extern function system(cmd: *u8): i32;
/** libc：文件与内存，供 patch 使用。 */
extern function fopen(path: *u8, mode: *u8): *u8;
extern function fclose(f: *u8): i32;
extern function fseek(f: *u8, off: i64, whence: i32): i32;
