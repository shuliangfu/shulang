// std.vec — 动态数组 Vec（自举前最小可用实现）
// 自举前：提供 Vec_i32 与 new/len/get/from_one；完整 push/pop 待 mut 或堆分配后扩展。

struct Vec_i32 {
  data: [8]i32;
  len: i32;
}

function vec_placeholder<T>(x: T): T { return x; }

function vec_len_empty(): i32 { return 0; }

function vec_new_i32(): Vec_i32 {
  return Vec_i32 { data: [], len: 0 }
}

function vec_len_i32(v: Vec_i32): i32 { return v.len; }

function vec_get_i32(v: Vec_i32, i: i32): i32 { return v.data[i]; }

function vec_from_one_i32(x: i32): Vec_i32 {
  return Vec_i32 { data: [x, 0, 0, 0, 0, 0, 0, 0], len: 1 }
}
