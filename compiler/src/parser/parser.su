/**
 * 初始化 arena 与 module 的计数/主函数下标；单独成函数以避免 codegen 将初始化语句移到 parse_into 循环之后。
 */
function parse_into_init(arena: *ASTArena, module: *Module): void {
  ast_arena_init(arena);
  module.num_funcs = 0;
  module.main_func_index = -1;
  module.num_imports = 0;
}

/**
 * 跳过顶层 import 语句：若当前 token 为 TOKEN_IMPORT 则消费至分号并继续，直到遇到非 import。
 * 返回跳过后的 lex，供 diag_lex_after_imports 等诊断路径使用（不收集 import 路径）。
 */
function skip_imports(lex: Lexer, source: []u8): Lexer {
  while (true) {
    let r: LexerResult = lexer_next(lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IMPORT) {
      return lex;
    }
    lex = r.next_lex;
    /* 消费本条 import 至分号（含 import path 如 ident 或 ident.ident） */
    while (true) {
      let r2: LexerResult = lexer_next(lex, source);
      if (r2.tok.kind == TokenKind.TOKEN_SEMICOLON) {
        lex = r2.next_lex;
        break;
      }
      if (r2.tok.kind == TokenKind.TOKEN_EOF) {
        return lex;
      }
      lex = r2.next_lex;
    }
  }
  return lex;
}

/**
 * 收集顶层 import 路径到 module，并通过 out 写出跳过 import 后的 lex。
 * 解析 import path;（path 为 ident 或 ident.ident），填充 module.import_paths / import_path_lens / num_imports。
 * 使用 out 参数避免按值返回 Lexer（ABI 导致有 import 时返回值错误），供 parse_into 在解析 function 前调用。
 */
function collect_imports(lex: Lexer, source: []u8, module: *Module, out: *CollectImportsResult): void {
  let path_buf: [64]u8 = [];
  let path_len: i32 = 0;
  out.lex = lex;
  while (true) {
    let r: LexerResult = lexer_next(out.lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IMPORT) {
      return;
    }
    out.lex = r.next_lex;
    /* 解析 path：ident 或 ident.ident */
    path_len = 0;
    r = lexer_next(out.lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      return;
    }
    if (r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
      return;
    }
    /* ident 起点：lexer 会跳过空白，故用 next_lex.pos - ident_len（与 parse_one_function 一致） */
    let ident_start: usize = r.next_lex.pos - r.tok.ident_len;
    copy_slice_to_name64(source, ident_start, r.tok.ident_len, path_buf);
    path_len = r.tok.ident_len;
    out.lex = r.next_lex;
    r = lexer_next(out.lex, source);
    while (r.tok.kind == TokenKind.TOKEN_DOT) {
      if (path_len >= 63) {
        return;
      }
      let dot_u8: u8 = 46;
      path_buf[path_len] = dot_u8;
      path_len = path_len + 1;
      out.lex = r.next_lex;
      r = lexer_next(out.lex, source);
      if (r.tok.kind != TokenKind.TOKEN_IDENT) {
        return;
      }
      if (path_len + r.tok.ident_len > 63) {
        return;
      }
      let i: i32 = 0;
      while (i < r.tok.ident_len) {
        if (out.lex.pos + i < source.length) {
          path_buf[path_len + i] = source[out.lex.pos + i];
        }
        i = i + 1;
      }
      path_len = path_len + r.tok.ident_len;
      out.lex = r.next_lex;
      r = lexer_next(out.lex, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      return;
    }
    if (module.num_imports >= 32) {
      return;
    }
    let base: i32 = module.num_imports * 64;
    let j: i32 = 0;
    while (j < 64) {
      if (j < path_len) {
        module.import_path_data[base + j] = path_buf[j];
      } else {
        let z: u8 = 0;
        module.import_path_data[base + j] = z;
      }
      j = j + 1;
    }
    module.import_path_lens[module.num_imports] = path_len;
    module.num_imports = module.num_imports + 1;
    out.lex = r.next_lex;
  }
}

/** 与 collect_imports 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function collect_imports_buf(lex: Lexer, data: *u8, len: i32, module: *Module, out: *CollectImportsResult): void {
  let path_buf: [64]u8 = [];
  let path_len: i32 = 0;
  out.lex = lex;
  while (true) {
    let r: LexerResult = lexer_next_buf(out.lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_IMPORT) {
      return;
    }
    out.lex = r.next_lex;
    path_len = 0;
    r = lexer_next_buf(out.lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      return;
    }
    if (r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
      return;
    }
    let ident_start: usize = r.next_lex.pos - r.tok.ident_len;
    copy_slice_to_name64_buf(data, len, ident_start, r.tok.ident_len, path_buf);
    path_len = r.tok.ident_len;
    out.lex = r.next_lex;
    r = lexer_next_buf(out.lex, data, len);
    while (r.tok.kind == TokenKind.TOKEN_DOT) {
      if (path_len >= 63) {
        return;
      }
      let dot_u8: u8 = 46;
      path_buf[path_len] = dot_u8;
      path_len = path_len + 1;
      out.lex = r.next_lex;
      r = lexer_next_buf(out.lex, data, len);
      if (r.tok.kind != TokenKind.TOKEN_IDENT) {
        return;
      }
      if (path_len + r.tok.ident_len > 63) {
        return;
      }
      let i: i32 = 0;
      while (i < r.tok.ident_len) {
        path_buf[path_len + i] = data[out.lex.pos + i];
        i = i + 1;
      }
      path_len = path_len + r.tok.ident_len;
      out.lex = r.next_lex;
      r = lexer_next_buf(out.lex, data, len);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      return;
    }
    if (module.num_imports >= 32) {
      return;
    }
    let base: i32 = module.num_imports * 64;
    let j: i32 = 0;
    while (j < 64) {
      if (j < path_len) {
        module.import_path_data[base + j] = path_buf[j];
      } else {
        let z: u8 = 0;
        module.import_path_data[base + j] = z;
      }
      j = j + 1;
    }
    module.import_path_lens[module.num_imports] = path_len;
    module.num_imports = module.num_imports + 1;
    out.lex = r.next_lex;
  }
}

/**
 * 跳过一条顶层 struct 定义：struct <ident> { ... }；lex 为 struct 前的位置。
 * 返回跳过后的 lex，供 parse_into 在解析 function 前跳过 codegen.su 等文件中的 struct。
 */
function skip_one_struct(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = lexer_next(lex, source);
  if (r.tok.kind != TokenKind.TOKEN_STRUCT) {
    return lex;
  }
  lex = r.next_lex;
  r = lexer_next(lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex = r.next_lex;
  r = lexer_next(lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces(r.next_lex, source);
  return lex;
}

/** 与 skip_one_struct 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function skip_one_struct_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_STRUCT) {
    return lex;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces_buf(r.next_lex, data, len);
  return lex;
}

/**
 * 与 parse_one_function 等价，接受 (data: *u8, len) 供 buf 路径使用；当前为精简实现，仅支持 function <ident>(): i32 { return <int>; } 及无参、无 let/const/if 的形态。
 * 完整形态（参数、let/const、if、乘除等）与 parse_one_function 一致，由同一定义处的 _buf 替换得到，见上方 parse_one_function。
 */
function parse_one_function_buf(lex: Lexer, data: *u8, len: i32): OneFuncResult {
  let empty32: [32]u8 = [];
  let dummy_pnames: [16][32]u8 = [empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32];
  let dummy_plens: [16]i32 = [];
  let empty64: [64]u8 = [];
  let dummy_name: [64]u8 = [];
  let dummy_const_names: [24][64]u8 = [empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64];
  let dummy_const_lens: [24]i32 = [];
  let dummy_const_vals: [24]i32 = [];
  let dummy_let_names: [24][64]u8 = [empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64];
  let dummy_let_lens: [24]i32 = [];
  let dummy_let_vals: [24]i32 = [];
  let fail: OneFuncResult = OneFuncResult { ok: false, next_lex: lex, name: dummy_name, name_len: 0, num_params: 0, param_names: dummy_pnames, param_name_lens: dummy_plens, num_consts: 0, const_names: dummy_const_names, const_name_lens: dummy_const_lens, const_init_vals: dummy_const_vals, num_lets: 0, let_names: dummy_let_names, let_name_lens: dummy_let_lens, let_init_vals: dummy_let_vals, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, has_unary_neg: false, return_val: 0, has_call_expr: false, call_callee_name: dummy_name, call_callee_len: 0 };
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return fail;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return fail;
  }
  let name_len: i32 = r.tok.ident_len;
  if (name_len <= 0 || name_len > 63) {
    return fail;
  }
  let name_start: usize = r.next_lex.pos - name_len;
  let name: [64]u8 = dummy_name;
  copy_slice_to_name64_buf(data, len, name_start, name_len, name);
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return fail;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
    return fail;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return fail;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_I32 && r.tok.kind != TokenKind.TOKEN_I64 && r.tok.kind != TokenKind.TOKEN_BOOL && r.tok.kind != TokenKind.TOKEN_VOID && r.tok.kind != TokenKind.TOKEN_U8 && r.tok.kind != TokenKind.TOKEN_U32 && r.tok.kind != TokenKind.TOKEN_U64 && r.tok.kind != TokenKind.TOKEN_IDENT) {
    return fail;
  }
  lex = r.next_lex;
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return fail;
  }
  lex = r.next_lex;
  r = body_skip_let_const_then_if_buf(lex, data, len);
  if (r.tok.kind == TokenKind.TOKEN_INT) {
    let ret_val: i32 = r.tok.int_val;
    lex = r.next_lex;
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
      return fail;
    }
    lex = r.next_lex;
    return OneFuncResult { ok: true, next_lex: lex, name: name, name_len: name_len, num_params: 0, param_names: dummy_pnames, param_name_lens: dummy_plens, num_consts: 0, const_names: dummy_const_names, const_name_lens: dummy_const_lens, const_init_vals: dummy_const_vals, num_lets: 0, let_names: dummy_let_names, let_name_lens: dummy_let_lens, let_init_vals: dummy_let_vals, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, has_unary_neg: false, return_val: ret_val, has_call_expr: false, call_callee_name: dummy_name, call_callee_len: 0 }
  }
  if (r.tok.kind == TokenKind.TOKEN_RETURN) {
    lex = r.next_lex;
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_INT) {
      return fail;
    }
    let ret_val: i32 = r.tok.int_val;
    lex = r.next_lex;
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_RBRACE) {
      return fail;
    }
    if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex = r.next_lex;
      r = lexer_next_buf(lex, data, len);
      if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
        return fail;
      }
    }
    lex = r.next_lex;
    return OneFuncResult { ok: true, next_lex: lex, name: name, name_len: name_len, num_params: 0, param_names: dummy_pnames, param_name_lens: dummy_plens, num_consts: 0, const_names: dummy_const_names, const_name_lens: dummy_const_lens, const_init_vals: dummy_const_vals, num_lets: 0, let_names: dummy_let_names, let_name_lens: dummy_let_lens, let_init_vals: dummy_let_vals, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, has_unary_neg: false, return_val: ret_val, has_call_expr: false, call_callee_name: dummy_name, call_callee_len: 0 }
  }
  return fail;
}

/**
 * 解析若干最小函数并填入 .su AST：每项为 function <ident>(): i32 { return <int>; }，遇非 function 或 EOF 停止。
 * 成功时填充 arena 与 module（funcs[0..num_funcs-1]）；main_idx 由调用方写回 module.main_func_index。
 * 返回 ParseIntoResult：ok 0 成功 -1 失败，main_idx 为 main 下标（无则 -1）。
 */
function parse_into(arena: *ASTArena, module: *Module, source: []u8): ParseIntoResult {
  /* 由调用方在调用 parse_into 前先调用 parse_into_init，避免 codegen 将 init 移到循环后 */
  let lex: Lexer = lexer_init();
  let main_idx: i32 = -1;
  /* 循环前一次性跳过顶层 import，通过 out 参数取 lex 避免按值返回 Lexer（ABI 导致有 import 时错误） */
  let import_res: CollectImportsResult = CollectImportsResult { lex: lex };
  collect_imports(lex, source, module, &import_res);
  lex = import_res.lex;
  while (true) {
    /* 跳过顶层 struct 定义（如 codegen.su 的 struct CodegenOutBuf），直到遇到 function */
    let r: LexerResult = lexer_next(lex, source);
    if (r.tok.kind == TokenKind.TOKEN_STRUCT) {
      lex = skip_one_struct(lex, source);
      continue;
    }
    if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
      break;
    }
    let res: OneFuncResult = parse_one_function(lex, source);
    if (!res.ok) {
      break;
    }
    /* 立即根据 res 判断是否 main 并存入数组，避免栈上变量被后续代码覆盖 */
    let is_main_storage: [1]i32 = [];
    if (res.name_len == 4 && res.name[0] == 109 && res.name[1] == 97 && res.name[2] == 105 && res.name[3] == 110) {
      is_main_storage[0] = 1;
    }
    if (module.num_funcs >= 256) {
      return ParseIntoResult { ok: -1, main_idx: -1 }
    }
    let type_ref: i32 = ast_arena_type_alloc(arena);
    if (type_ref == 0) {
      return ParseIntoResult { ok: -1, main_idx: -1 }
    }
    let t: Type = ast_arena_type_get(arena, type_ref);
    t.kind = TypeKind.TYPE_I32;
    t.name_len = 0;
    t.elem_type_ref = 0;
    t.array_size = 0;
    ast_arena_type_set(arena, type_ref, t);

    let expr_ref: i32 = ast_arena_expr_alloc(arena);
    if (expr_ref == 0) {
      return ParseIntoResult { ok: -1, main_idx: -1 }
    }
    let e: Expr = ast_arena_expr_get(arena, expr_ref);
    e.kind = ExprKind.EXPR_LIT;
    e.resolved_type_ref = type_ref;
    e.line = 0;
    e.col = 0;
    e.int_val = res.return_val;
    e.binop_left_ref = 0;
    e.binop_right_ref = 0;
    e.unary_operand_ref = 0;
    e.if_cond_ref = 0;
    e.if_then_ref = 0;
    e.if_else_ref = 0;
    e.block_ref = 0;
    e.match_matched_ref = 0;
    e.match_num_arms = 0;
    ast.expr_init_match_enum(&e);
    e.field_access_base_ref = 0;
    e.field_access_field_len = 0;
    e.field_access_is_enum_variant = 0;
    e.field_access_offset = 0;
    e.index_base_ref = 0;
    e.index_index_ref = 0;
    e.index_base_is_slice = 0;
    e.call_callee_ref = 0;
    e.call_num_args = 0;
    e.method_call_base_ref = 0;
    e.method_call_name_len = 0;
    e.method_call_num_args = 0;
    e.const_folded_val = 0;
    e.const_folded_valid = 0;
    e.index_proven_in_bounds = 0;
    ast_arena_expr_set(arena, expr_ref, e);

    let final_expr_ref: i32 = expr_ref;
    if (res.has_mul && !res.has_binop) {
      let mul_right_ref: i32 = ast_arena_expr_alloc(arena);
      if (mul_right_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let mre: Expr = ast_arena_expr_get(arena, mul_right_ref);
      mre.kind = ExprKind.EXPR_LIT;
      mre.resolved_type_ref = type_ref;
      mre.line = 0;
      mre.col = 0;
      mre.int_val = res.mul_right_val;
      mre.binop_left_ref = 0;
      mre.binop_right_ref = 0;
      mre.unary_operand_ref = 0;
      mre.if_cond_ref = 0;
      mre.if_then_ref = 0;
      mre.if_else_ref = 0;
      mre.block_ref = 0;
      mre.match_matched_ref = 0;
      mre.match_num_arms = 0;
      ast.expr_init_match_enum(&mre);
      mre.field_access_base_ref = 0;
      mre.field_access_field_len = 0;
      mre.field_access_is_enum_variant = 0;
      mre.field_access_offset = 0;
      mre.index_base_ref = 0;
      mre.index_index_ref = 0;
      mre.index_base_is_slice = 0;
      mre.call_callee_ref = 0;
      mre.call_num_args = 0;
      mre.method_call_base_ref = 0;
      mre.method_call_name_len = 0;
      mre.method_call_num_args = 0;
      mre.const_folded_val = 0;
      mre.const_folded_valid = 0;
      mre.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, mul_right_ref, mre);
      let mul_ref: i32 = ast_arena_expr_alloc(arena);
      if (mul_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let me: Expr = ast_arena_expr_get(arena, mul_ref);
      me.kind = ExprKind.EXPR_MUL;
      me.resolved_type_ref = type_ref;
      me.line = 0;
      me.col = 0;
      me.int_val = 0;
      me.binop_left_ref = final_expr_ref;
      me.binop_right_ref = mul_right_ref;
      me.unary_operand_ref = 0;
      me.if_cond_ref = 0;
      me.if_then_ref = 0;
      me.if_else_ref = 0;
      me.block_ref = 0;
      me.match_matched_ref = 0;
      me.match_num_arms = 0;
      ast.expr_init_match_enum(&me);
      me.field_access_base_ref = 0;
      me.field_access_field_len = 0;
      me.field_access_is_enum_variant = 0;
      me.field_access_offset = 0;
      me.index_base_ref = 0;
      me.index_index_ref = 0;
      me.index_base_is_slice = 0;
      me.call_callee_ref = 0;
      me.call_num_args = 0;
      me.method_call_base_ref = 0;
      me.method_call_name_len = 0;
      me.method_call_num_args = 0;
      me.const_folded_val = 0;
      me.const_folded_valid = 0;
      me.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, mul_ref, me);
      final_expr_ref = mul_ref;
    }
    if (res.has_if_expr) {
      let bool_type_ref: i32 = ast_arena_type_alloc(arena);
      if (bool_type_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let bt: Type = ast_arena_type_get(arena, bool_type_ref);
      bt.kind = TypeKind.TYPE_BOOL;
      bt.name_len = 0;
      bt.elem_type_ref = 0;
      bt.array_size = 0;
      ast_arena_type_set(arena, bool_type_ref, bt);
      let cond_ref: i32 = ast_arena_expr_alloc(arena);
      if (cond_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let ce: Expr = ast_arena_expr_get(arena, cond_ref);
      ce.kind = ExprKind.EXPR_BOOL_LIT;
      ce.resolved_type_ref = bool_type_ref;
      ce.line = 0;
      ce.col = 0;
      if (res.if_cond_true) {
        ce.int_val = 1;
      } else {
        ce.int_val = 0;
      }
      ce.binop_left_ref = 0;
      ce.binop_right_ref = 0;
      ce.unary_operand_ref = 0;
      ce.if_cond_ref = 0;
      ce.if_then_ref = 0;
      ce.if_else_ref = 0;
      ce.block_ref = 0;
      ce.match_matched_ref = 0;
      ce.match_num_arms = 0;
      ast.expr_init_match_enum(&ce);
      ce.field_access_base_ref = 0;
      ce.field_access_field_len = 0;
      ce.field_access_is_enum_variant = 0;
      ce.field_access_offset = 0;
      ce.index_base_ref = 0;
      ce.index_index_ref = 0;
      ce.index_base_is_slice = 0;
      ce.call_callee_ref = 0;
      ce.call_num_args = 0;
