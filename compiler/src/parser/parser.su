/**
 * 从 source[start..start+nlen] 复制到 out[0..nlen-1]，避免 codegen 将复制循环提升到 FUNCTION 分支前。
 * 调用方在分支内传入 name（C 中数组按指针传递），保证复制在正确控制流下执行。
 */
function copy_slice_to_name64(source: []u8, start: usize, nlen: i32, out: [64]u8): void {
  let i: i32 = 0;
  while (i < nlen) {
    if (start + i < source.length) {
      out[i] = source[start + i];
    }
    i = i + 1;
  }
}

/** 与 copy_slice_to_name64 等价，接受 (source: *u8, source_len) 供 buf 路径使用。调用方须保证 start + nlen 在 source 范围内。 */
function copy_slice_to_name64_buf(source: *u8, source_len: i32, start: usize, nlen: i32, out: [64]u8): void {
  let i: i32 = 0;
  while (i < nlen) {
    out[i] = source[start + i];
    i = i + 1;
  }
}


