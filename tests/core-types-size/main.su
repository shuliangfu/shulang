// 测试 core.types 的 size_of_* 与 core.debug.assert（通过 import 后直接调用）
import core.types;
import core.debug;

function main(): i32 {
  let s32: i32 = size_of_i32();
  let sb: i32 = size_of_bool();
  let ok1: i32 = assert(s32 == 4);
  let ok2: i32 = assert(sb == 1);
  return if (s32 != 4) { 1 } else if (sb != 1) { 2 } else { 0 }
}
