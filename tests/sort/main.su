// tests/sort/main.su — std.sort 回归：sort_i32、sort_u8。
import std.sort;
import core.debug;

function main(): i32 {
  let a: [4]i32 = [3, 1, 4, 2];
  sort_i32(&a[0], 4);
  assert_eq_i32(a[0], 1);
  assert_eq_i32(a[1], 2);
  assert_eq_i32(a[2], 3);
  assert_eq_i32(a[3], 4);
  let b: [3]u8 = [200, 100, 150];
  sort_u8(&b[0], 3);
  let b0: u32 = b[0];
  let b1: u32 = b[1];
  let b2: u32 = b[2];
  assert_eq_u32(b0, 100);
  assert_eq_u32(b1, 150);
  assert_eq_u32(b2, 200);
  return 0;
}
