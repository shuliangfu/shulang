// 测试 core.mem：placeholder、align_of_*、align_up/down、mem_copy/mem_set/mem_move、mem_compare、mem_zero、mem_swap、is_alignment_power_of_two
import core.mem;

function main(): i32 {
  let ph: i32 = placeholder();
  if (ph != 0) { return 21; }
  if (align_of_pointer() != 8) { return 20; }
  let a: i32 = align_of_i32();
  if (a != 4) { return 1; }
  let up: usize = align_up(7, 4);
  if (up != 8) { return 2; }
  let down: usize = align_down(7, 4);
  if (down != 4) { return 3; }
  let buf: [4]u8 = [10, 20, 30, 40];
  let dst: [4]u8 = [0, 0, 0, 0];
  mem_copy(dst, buf, 4);
  if (dst[0] != 10 || dst[1] != 20 || dst[2] != 30 || dst[3] != 40) { return 4; }
  mem_set(dst, 7, 4);
  if (dst[0] != 7 || dst[3] != 7) { return 5; }
  let arr: [4]u8 = [1, 2, 3, 4];
  mem_move(arr, arr, 3);
  if (arr[0] != 1 || arr[1] != 2 || arr[2] != 3 || arr[3] != 4) { return 6; }
  let p: [4]u8 = [5, 6, 7, 8];
  mem_move(p, buf, 2);
  if (p[0] != 10 || p[1] != 20 || p[2] != 7 || p[3] != 8) { return 10; }
  let x: [2]u8 = [1, 2];
  let y: [2]u8 = [1, 2];
  let z: [2]u8 = [1, 3];
  if (mem_compare(x, y, 2) != 0) { return 7; }
  if (mem_compare(x, z, 2) >= 0) { return 8; }
  if (mem_compare(z, x, 2) <= 0) { return 9; }
  mem_zero(dst, 4);
  if (dst[0] != 0 || dst[3] != 0) { return 11; }
  let s1: [2]u8 = [1, 2];
  let s2: [2]u8 = [9, 8];
  mem_swap(s1, s2, 2);
  if (s1[0] != 9 || s1[1] != 8 || s2[0] != 1 || s2[1] != 2) { return 12; }
  if (!is_alignment_power_of_two(4)) { return 13; }
  if (is_alignment_power_of_two(0)) { return 14; }
  if (is_alignment_power_of_two(3)) { return 15; }
  return 0;
}
