// core.types — 基础类型别名、size_of/align_of 等（自举前最小实现）
// 自举前：提供基础类型大小与对齐的常量函数；完整 size_of(T)/align_of(T) 可由内建扩展。

function placeholder(): i32 { return 0; }

// 基础类型大小（字节），供自举前使用；与变量类型与类型系统设计一致。
function size_of_i32(): i32 { return 4; }
function size_of_bool(): i32 { return 1; }
function size_of_u8(): i32 { return 1; }
function size_of_u32(): i32 { return 4; }
function size_of_u64(): i32 { return 8; }
function size_of_i64(): i32 { return 8; }
function size_of_usize(): i32 { return 8; }
function size_of_isize(): i32 { return 8; }
function size_of_f32(): i32 { return 4; }
function size_of_f64(): i32 { return 8; }
